{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "incremental": false,
    "strict": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist"]
}
